# App
PORT=8000

# Database (Supabase Postgres)
# Supabase dashboard → Project Settings → Database → Connection parameters
# Use port 6543 (pooler, transaction mode) for serverless/most backends,
# or 5432 (direct) if you need session-level features (LISTEN/NOTIFY, prepared statements).
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=

# Auth (JWT)
JWT_SECRET=change-me
JWT_TTL_MINUTES=60

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_SUBSCRIPTION_SUCCESS_URL=
STRIPE_SUBSCRIPTION_CANCEL_URL=
STRIPE_CONNECT_RETURN_URL=

# Storage (Supabase Storage)
# Project Settings → API. Service role key bypasses RLS — server-side only, never expose to clients.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=aura-uploads
