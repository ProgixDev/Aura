# App
PORT=8000

# Database (Supabase Postgres)
# Use the pooler, not the direct host: db.<ref>.supabase.co is IPv6-only and fails
# outright (DNS ENOTFOUND) on any network/machine without IPv6 — a common local-dev
# footgun. Get the exact host from Project Settings → Database → Connection pooling
# (mode = Transaction) — it encodes your project's region, which isn't derivable from
# the project ref or any API call.
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=

# Auth (JWT)
JWT_SECRET=change-me
JWT_TTL_MINUTES=60

# Stripe
# Pro/Premium subscription Prices are auto-provisioned on first checkout call
# (StripeService.findOrCreatePrice, keyed by a stable lookup_key) — no dashboard setup,
# no price-id env vars needed. Success/cancel/Connect-return URLs default to mobile deep
# links if left blank — only set them if testing checkout through the web app in a browser.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_SUCCESS_URL=
STRIPE_SUBSCRIPTION_CANCEL_URL=
STRIPE_CONNECT_RETURN_URL=

# Storage (Supabase Storage)
# Project Settings → API. Service role key bypasses RLS — server-side only, never expose to clients.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=aura-uploads

# Email (SMTP)
# Gmail: create an App Password (Account → Security → 2-Step Verification → App
# passwords), not your normal password. Port 587 uses STARTTLS (SMTP_SECURE=false);
# use port 465 with SMTP_SECURE=true for implicit TLS. SMTP_FROM is the visible
# sender; leave blank to default to SMTP_USER.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# Where public/anonymous "contact us" forms land (about page, disciplines, blog,
# events…). Optional — defaults to SMTP_FROM, then SMTP_USER, if left blank.
CONTACT_INBOX=
